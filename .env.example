# ── RECOMMENDED ──────────────────────────────────────────────────────────────
# Add your Anthropic key so you can switch back to real Claude via the Admin UI
# without touching any env vars or restarting Claude Desktop.
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# NVIDIA NIM — https://build.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here

# OpenAI — https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key-here

# Groq (free tier) — https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Mistral — https://console.mistral.ai
MISTRAL_API_KEY=your-mistral-api-key-here

# Together AI — https://api.together.xyz
TOGETHER_API_KEY=your-together-api-key-here

# OpenRouter — https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic (fallback to real Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama runs locally — no key needed
# Install from https://ollama.com then: ollama pull llama3.2

PORT=8082
